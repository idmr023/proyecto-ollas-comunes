SUPABASE_URL="https://tu-proyecto.supabase.co"
SUPABASE_SECRET_KEY="tu-secret-key"
SUPABASE_HEALTHCHECK_TABLE="tenants"
PORT=4000
HOST=0.0.0.0
PUBLIC_URL=
ALLOWED_ORIGINS="http://localhost:3000"
# En producción este valor es OBLIGATORIO (orígenes separados por coma).
# Ejemplo: ALLOWED_ORIGINS="https://app.tu-dominio.com,https://admin.tu-dominio.com"
JWT_SECRET="cambiar-por-secreto-seguro"

# Prisma - Transaction Pooler (PgBouncer) de Supabase
# Obtener de Supabase > Settings > Database > Connection string (Transaction pooler)
# ?pgbouncer=true deshabilita prepared statements (incompatibles con PgBouncer)
# SSL se configura via PoolConfig en prisma.ts (rejectUnauthorized: false para Supabase)
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Groq AI API Key y Modelo (Recomendación de Menús)
# Obtener API key en https://console.groq.com/
GROQ_API_KEY="tu-groq-api-key"
GROQ_MODEL="llama-3.3-70b-versatile"

# Clave de cifrado simétrico para datos en reposo (AES-256)
# Debe ser un hex string de 64 caracteres en producción
DB_ENCRYPTION_KEY="f9c1db86bf091e847c2fa8e71b569e2cb9287c88b22a0a2df25f543e5c9429eb"

