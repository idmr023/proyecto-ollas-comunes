SUPABASE_URL="https://tu-proyecto.supabase.co"
SUPABASE_SECRET_KEY="tu-secret-key"
SUPABASE_HEALTHCHECK_TABLE="tenants"
PORT=4000
HOST=0.0.0.0
PUBLIC_URL=
ALLOWED_ORIGINS="http://localhost:3000"
JWT_SECRET="cambiar-por-secreto-seguro"

# IA / jobs
# Clave de Gemini para las sugerencias de menú (si falta, el job degrada con fallback).
GEMINI_API_KEY=""
# Secreto para autorizar el endpoint interno del job (cabecera x-job-secret).
JOB_SECRET="cambiar-por-secreto-de-job"

# Correo
# En desarrollo, muestra el OTP en la terminal y no envia correos.
EMAIL_MODE="console"
# En produccion usa EMAIL_MODE="smtp" y configura SMTP_HOST, SMTP_PORT,
# SMTP_USER, SMTP_PASS y SMTP_FROM.

# Prisma - Transaction Pooler (PgBouncer) de Supabase
# Obtener de Supabase > Settings > Database > Connection string (Transaction pooler)
# ?pgbouncer=true deshabilita prepared statements (incompatibles con PgBouncer)
# SSL se configura via PoolConfig en prisma.ts (rejectUnauthorized: false para Supabase)
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
