generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TenantStatus {
  active
  inactive

  @@map("tenants_status_check")
}

enum UserRole {
  admin_municipal
  lideresa_olla
  supervisor
  operador_olla
  coordinador

  @@map("app_users_role_check")
}

enum UserStatus {
  active
  inactive

  @@map("app_users_status_check")
}

enum OllaStatus {
  active
  inactive

  @@map("ollas_comunes_status_check")
}

enum Gender {
  male
  female
  other
  not_specified

  @@map("beneficiaries_gender_check")
}

enum PriorityLevel {
  low
  normal
  high

  @@map("beneficiaries_priority_level_check")
}

enum HealthConditionStatus {
  active
  inactive

  @@map("health_conditions_status_check")
}

enum SourceType {
  municipality
  ngo
  company
  private_donor
  local_purchase

  @@map("supply_sources_source_type_check")
}

enum SupplySourceStatus {
  active
  inactive

  @@map("supply_sources_status_check")
}

enum SupplyUnit {
  kg
  g
  lt
  ml
  un

  @@map("supply_items_unit_check")
}

enum SupplyItemStatus {
  active
  inactive

  @@map("supply_items_status_check")
}

enum MovementType {
  in
  out
  adjustment
  waste

  @@map("inventory_movements_movement_type_check")
}

enum RecipeStatus {
  active
  inactive

  @@map("recipes_status_check")
}

enum MenuPlanStatus {
  draft
  approved
  executed
  cancelled

  @@map("menu_plans_status_check")
}

enum SuggestedByType {
  user
  ia

  @@map("menu_plans_suggested_by_type_check")
}

enum RecommendationType {
  menu
  priority
  stock_alert

  @@map("recommendations_recommendation_type_check")
}

enum GeneratedByType {
  ia
  system
  user

  @@map("recommendations_generated_by_type_check")
}

enum RecommendationStatus {
  pending
  approved
  rejected
  applied

  @@map("recommendations_status_check")
}

enum AlertType {
  low_stock
  unusual_consumption
  missing_daily_report
  high_priority_beneficiary
  new_beneficiary
  sync_conflict

  @@map("alerts_alert_type_check")
}

enum AlertSeverity {
  low
  medium
  high
  critical

  @@map("alerts_severity_check")
}

enum AlertStatus {
  open
  in_progress
  resolved
  dismissed

  @@map("alerts_status_check")
}

enum DocumentType {
  evidence
  report
  acta
  photo
  other

  @@map("documents_document_type_check")
}

enum ActionType {
  insert
  update
  delete

  @@map("audit_logs_action_type_check")
}

model Tenant {
  id        String         @id @default(uuid()) @db.Uuid
  code      String         @unique @db.VarChar(50)
  name      String         @db.VarChar(150)
  category  String         @default("Municipalidad") @db.VarChar(100)
  location  String         @default("Lima") @db.VarChar(100)
  status    String         @default("active") @db.VarChar(20)
  createdAt DateTime       @default(now()) @map("created_at")
  appUsers  AppUser[]
  ollas     OllaComun[]
  beneficiaries Beneficiary[]
  supplySources SupplySource[]
  inventoryMovements InventoryMovement[]
  recipes   Recipe[]
  recommendations Recommendation[]
  alerts    Alert[]
  documents Document[]

  @@map("tenants")
}

model AppUser {
  id           String       @id @default(uuid()) @db.Uuid
  tenantId     String       @map("tenant_id") @db.Uuid
  email        String       @unique
  fullName     String       @map("full_name") @db.VarChar(150)
  passwordHash String       @map("password_hash")
  role         String       @db.VarChar(30)
  status       String       @default("active") @db.VarChar(20)
  totpSecret   String?      @map("totp_secret") @db.VarChar(255)
  // Olla a cargo del usuario. Obligatoria en la practica para `lideresa_olla`;
  // nula para roles administrativos, que operan sobre toda la organizacion.
  // Sin esta columna no habia forma de saber que olla gestiona cada lideresa.
  ollaId       String?      @map("olla_id") @db.Uuid
  createdAt    DateTime     @default(now()) @map("created_at")
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  olla         OllaComun?   @relation(fields: [ollaId], references: [id], onDelete: SetNull)
  inventoryMovements InventoryMovement[]
  menuPlans    MenuPlan[]
  mealDeliveries MealDelivery[]
  recommendations Recommendation[]
  documents    Document[]
  auditLogs    AuditLog[]
  @@index([tenantId])
  @@index([ollaId])
  @@map("app_users")
}

model District {
  id    Int          @id @default(autoincrement()) @db.SmallInt
  name  String       @unique @db.VarChar(100)
  ollas OllaComun[]

  @@map("districts")
}

model OllaComun {
  id                   String                @id @default(uuid()) @db.Uuid
  tenantId             String                @map("tenant_id") @db.Uuid
  districtId           Int?                  @map("district_id") @db.SmallInt
  code                 String                @db.VarChar(50)
  name                 String                @db.VarChar(150)
  address              String?
  latitude             Float?
  longitude            Float?
  contactName          String?               @map("contact_name") @db.VarChar(150)
  contactPhone         String?               @map("contact_phone") @db.VarChar(30)
  estimatedDailyCapacity Int?                @map("estimated_daily_capacity")
  status               String                @default("active") @db.VarChar(20)
  createdAt            DateTime              @default(now()) @map("created_at")
  tenant               Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  district             District?             @relation(fields: [districtId], references: [id])
  beneficiaries        Beneficiary[]
  assignedUsers        AppUser[]
  inventoryMovements   InventoryMovement[]
  inventoryStocks      InventoryStock[]
  menuPlans            MenuPlan[]
  recommendations      Recommendation[]
  alerts               Alert[]
  documents            Document[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([districtId])
  @@map("ollas_comunes")
}

model Beneficiary {
  id           String                     @id @default(uuid()) @db.Uuid
  tenantId     String                     @map("tenant_id") @db.Uuid
  ollaId       String?                    @map("olla_id") @db.Uuid
  dni          String?                    @unique @db.VarChar(128)
  firstName    String                     @map("first_name") @db.VarChar(100)
  lastName     String                     @map("last_name") @db.VarChar(100)
  gender       String                     @default("not_specified") @db.VarChar(20)
  birthDate    DateTime                   @map("birth_date") @db.Date
  phone        String?                    @db.VarChar(30)
  address      String?
  priorityLevel String                    @default("normal") @map("priority_level") @db.VarChar(20)
  status       String                     @default("active") @db.VarChar(20)
  registeredAt DateTime                   @default(now()) @map("registered_at")
  tenant       Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  olla         OllaComun?                 @relation(fields: [ollaId], references: [id], onDelete: SetNull)
  healthConditions BeneficiaryHealthCondition[]
  mealDeliveryDetails MealDeliveryDetail[]

  @@index([tenantId])
  @@index([ollaId])
  @@index([status])
  @@map("beneficiaries")
}

model HealthCondition {
  id          Int                          @id @default(autoincrement()) @db.SmallInt
  name        String                       @unique @db.VarChar(100)
  status      String                       @default("active") @db.VarChar(20)
  beneficiaries BeneficiaryHealthCondition[]

  @@map("health_conditions")
}

model BeneficiaryHealthCondition {
  beneficiaryId    String           @map("beneficiary_id") @db.Uuid
  healthConditionId Int             @map("health_condition_id") @db.SmallInt
  notes            String?
  beneficiary      Beneficiary      @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)
  healthCondition  HealthCondition  @relation(fields: [healthConditionId], references: [id], onDelete: Restrict)

  @@id([beneficiaryId, healthConditionId])
  @@map("beneficiary_health_conditions")
}

model SupplyCategory {
  id    Int           @id @default(autoincrement()) @db.SmallInt
  name  String        @unique @db.VarChar(100)
  items SupplyItem[]

  @@map("supply_categories")
}

model SupplySource {
  id          String             @id @default(uuid()) @db.Uuid
  tenantId    String             @map("tenant_id") @db.Uuid
  sourceType  String             @map("source_type") @db.VarChar(30)
  name        String             @db.VarChar(150)
  contactName String?            @map("contact_name") @db.VarChar(150)
  contactPhone String?           @map("contact_phone") @db.VarChar(30)
  notes       String?
  status      String             @default("active") @db.VarChar(20)
  createdAt   DateTime           @default(now()) @map("created_at")
  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inventoryMovements InventoryMovement[]

  @@index([tenantId])
  @@index([sourceType])
  @@map("supply_sources")
}

model SupplyItem {
  id           String                @id @default(uuid()) @db.Uuid
  categoryId   Int?                  @map("category_id") @db.SmallInt
  name         String                @db.VarChar(120)
  unit         String                @db.VarChar(20)
  isPerishable Boolean               @default(true) @map("is_perishable")
  status       String                @default("active") @db.VarChar(20)
  category     SupplyCategory?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  inventoryMovements InventoryMovement[]
  inventoryStocks    InventoryStock[]
  recipeIngredients  RecipeIngredient[]

  @@unique([name, unit])
  @@map("supply_items")
}

model InventoryMovement {
  id            String         @id @default(uuid()) @db.Uuid
  tenantId      String         @map("tenant_id") @db.Uuid
  ollaId        String         @map("olla_id") @db.Uuid
  supplyItemId  String         @map("supply_item_id") @db.Uuid
  sourceId      String?        @map("source_id") @db.Uuid
  movementType  String         @map("movement_type") @db.VarChar(20)
  quantity      Decimal        @db.Decimal(12, 2)
  movementDate  DateTime       @default(now()) @map("movement_date")
  notes         String?
  createdBy     String?        @map("created_by") @db.Uuid
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  olla          OllaComun      @relation(fields: [ollaId], references: [id], onDelete: Cascade)
  supplyItem    SupplyItem     @relation(fields: [supplyItemId], references: [id], onDelete: Restrict)
  source        SupplySource?  @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  createdByUser AppUser?       @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([ollaId])
  @@index([supplyItemId])
  @@index([sourceId])
  @@index([movementDate])
  @@map("inventory_movements")
}

model InventoryStock {
  ollaId       String       @map("olla_id") @db.Uuid
  supplyItemId String       @map("supply_item_id") @db.Uuid
  quantity     Decimal      @default(0) @db.Decimal(12, 2)
  updatedAt    DateTime     @default(now()) @map("updated_at")
  olla         OllaComun    @relation(fields: [ollaId], references: [id], onDelete: Cascade)
  supplyItem   SupplyItem   @relation(fields: [supplyItemId], references: [id], onDelete: Restrict)

  @@id([ollaId, supplyItemId])
  @@map("inventory_stock")
}

model Recipe {
  id               String              @id @default(uuid()) @db.Uuid
  tenantId         String              @map("tenant_id") @db.Uuid
  name             String              @db.VarChar(150)
  description      String?
  estimatedServings Int                @default(1) @map("estimated_servings")
  status           String              @default("active") @db.VarChar(20)
  createdAt        DateTime            @default(now()) @map("created_at")
  tenant           Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ingredients      RecipeIngredient[]
  menuPlans        MenuPlan[]
  recommendations  Recommendation[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("recipes")
}

model RecipeIngredient {
  recipeId     String     @map("recipe_id") @db.Uuid
  supplyItemId String     @map("supply_item_id") @db.Uuid
  quantity     Decimal    @db.Decimal(12, 2)
  unit         String     @db.VarChar(20)
  notes        String?
  recipe       Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  supplyItem   SupplyItem @relation(fields: [supplyItemId], references: [id], onDelete: Restrict)

  @@id([recipeId, supplyItemId])
  @@map("recipe_ingredients")
}

model MenuPlan {
  id               String            @id @default(uuid()) @db.Uuid
  ollaId           String            @map("olla_id") @db.Uuid
  recipeId         String?           @map("recipe_id") @db.Uuid
  operationDate    DateTime          @map("operation_date") @db.Date
  dishName         String            @map("dish_name") @db.VarChar(150)
  plannedServings  Int               @map("planned_servings")
  suggestedByType  String            @default("user") @map("suggested_by_type") @db.VarChar(20)
  createdBy        String?           @map("created_by") @db.Uuid
  status           String            @default("draft") @db.VarChar(20)
  createdAt        DateTime          @default(now()) @map("created_at")
  olla             OllaComun         @relation(fields: [ollaId], references: [id], onDelete: Cascade)
  recipe           Recipe?           @relation(fields: [recipeId], references: [id], onDelete: SetNull)
  createdByUser    AppUser?          @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  deliveries       MealDelivery[]

  @@unique([ollaId, operationDate])
  @@index([ollaId])
  @@index([operationDate])
  @@index([recipeId])
  @@map("menu_plans")
}

model MealDelivery {
  id           String                @id @default(uuid()) @db.Uuid
  menuPlanId   String                @map("menu_plan_id") @db.Uuid
  deliveredAt  DateTime              @default(now()) @map("delivered_at")
  totalRations Int                   @map("total_rations")
  createdBy    String?               @map("created_by") @db.Uuid
  menuPlan     MenuPlan              @relation(fields: [menuPlanId], references: [id], onDelete: Cascade)
  createdByUser AppUser?             @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  details      MealDeliveryDetail[]

  @@index([menuPlanId])
  @@map("meal_deliveries")
}

model MealDeliveryDetail {
  deliveryId    String       @map("delivery_id") @db.Uuid
  beneficiaryId String       @map("beneficiary_id") @db.Uuid
  rationType    String?      @map("ration_type") @db.VarChar(50)
  delivery      MealDelivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  beneficiary   Beneficiary  @relation(fields: [beneficiaryId], references: [id], onDelete: Restrict)

  @@id([deliveryId, beneficiaryId])
  @@map("meal_delivery_details")
}

model Recommendation {
  id                 String               @id @default(uuid()) @db.Uuid
  tenantId           String               @map("tenant_id") @db.Uuid
  ollaId             String?              @map("olla_id") @db.Uuid
  recommendationType String               @map("recommendation_type") @db.VarChar(30)
  targetDate         DateTime?            @map("target_date") @db.Date
  relatedRecipeId    String?              @map("related_recipe_id") @db.Uuid
  title              String               @db.VarChar(150)
  description        String?
  generatedByType    String               @default("ia") @map("generated_by_type") @db.VarChar(20)
  status             String               @default("pending") @db.VarChar(20)
  approvedBy         String?              @map("approved_by") @db.Uuid
  approvedAt         DateTime?            @map("approved_at")
  createdAt          DateTime             @default(now()) @map("created_at")
  tenant             Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  olla               OllaComun?           @relation(fields: [ollaId], references: [id], onDelete: Cascade)
  relatedRecipe      Recipe?              @relation(fields: [relatedRecipeId], references: [id], onDelete: SetNull)
  approvedByUser     AppUser?             @relation(fields: [approvedBy], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([ollaId])
  @@index([recommendationType])
  @@index([status])
  @@map("recommendations")
}

model Alert {
  id          String       @id @default(uuid()) @db.Uuid
  tenantId    String       @map("tenant_id") @db.Uuid
  ollaId      String?      @map("olla_id") @db.Uuid
  alertType   String       @map("alert_type") @db.VarChar(50)
  severity    String       @default("medium") @db.VarChar(20)
  message     String
  status      String       @default("open") @db.VarChar(20)
  detectedAt  DateTime     @default(now()) @map("detected_at")
  resolvedAt  DateTime?    @map("resolved_at")
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  olla        OllaComun?   @relation(fields: [ollaId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([ollaId])
  @@index([status])
  @@map("alerts")
}

model Document {
  id           String     @id @default(uuid()) @db.Uuid
  tenantId     String     @map("tenant_id") @db.Uuid
  ollaId       String?    @map("olla_id") @db.Uuid
  uploadedBy   String?    @map("uploaded_by") @db.Uuid
  documentType String     @map("document_type") @db.VarChar(30)
  title        String     @db.VarChar(150)
  fileUrl      String     @map("file_url")
  description  String?
  uploadedAt   DateTime   @default(now()) @map("uploaded_at")
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  olla         OllaComun? @relation(fields: [ollaId], references: [id], onDelete: Cascade)
  uploadedByUser AppUser? @relation(fields: [uploadedBy], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([ollaId])
  @@index([documentType])
  @@map("documents")
}

model FailedSyncBackup {
  id              BigInt   @id @default(autoincrement())
  tenantId        String?  @map("tenant_id") @db.Uuid
  userId          String?  @map("user_id") @db.Uuid
  path            String   @db.VarChar(500)
  method          String   @db.VarChar(10)
  body            Json?    @db.JsonB
  errorMessage    String?
  status          Int?
  originalTimestamp DateTime @map("original_timestamp")
  reportedAt      DateTime @default(now()) @map("reported_at")
  emailSent       Boolean  @default(false) @map("email_sent")

  @@index([tenantId])
  @@index([userId])
  @@index([reportedAt])
  @@map("failed_sync_backups")
}

model AuditLog {
  id         BigInt     @id @default(autoincrement())
  tableName  String     @map("table_name") @db.VarChar(100)
  recordId   String?    @map("record_id")
  actionType String     @map("action_type") @db.VarChar(20)
  oldData    Json?      @map("old_data") @db.JsonB
  newData    Json?      @map("new_data") @db.JsonB
  changedBy  String?    @map("changed_by") @db.Uuid
  changedAt  DateTime   @default(now()) @map("changed_at")
  changedByUser AppUser? @relation(fields: [changedBy], references: [id], onDelete: SetNull)

  @@index([tableName])
  @@index([recordId])
  @@index([actionType])
  @@index([changedAt])
  @@index([changedBy])
  @@map("audit_logs")
}
